<!DOCTYPE html>
<html lang="my">
<head>
    <meta charset="UTF-8">
    <title>လချုပ်စာရင်း</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .main-content { 
            margin-left: 280px; 
            padding: 20px; 
            min-height: 100vh;
            background-color: #f8f9fa;
        }
    </style>
</head>

<body class="d-flex">
    <%- include('../partials/sidebar') %>

    <div class="main-content w-100">
        <div class="d-flex justify-content-between align-items-center">
            <h4>📊 လချုပ်စာရင်းကြည့်ရန်</h4>
            <span class="badge bg-success text-white">ကာလ - <%= monthFilter %></span>
        </div>
        <hr>

        <form action="/report/monthly" method="GET" class="row g-3 mb-4 bg-white p-3 shadow-sm rounded">
            <div class="col-md-3">
                <label class="form-label">လရွေးပါ</label>
                <input type="month" name="month" class="form-control" value="<%= monthFilter %>">
            </div>
            
            <div class="col-md-3">
                <label class="form-label">အမျိုးအမည် (Item Name)</label>
                <input type="text" name="itemName" class="form-control" placeholder="ဥပမာ - မြရော"
                       value="<%= typeof nameFilter !== 'undefined' ? nameFilter : '' %>">
            </div>

            <div class="col-md-3">
                <label class="form-label">အမျိုးအစား (Type)</label>
                <input type="text" name="type" class="form-control" placeholder="ဥပမာ - ပဲ"
                       value="<%= typeof typeFilter !== 'undefined' ? typeFilter : '' %>">
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-success w-100">စာရင်းထုတ်မည်</button>
            </div>
        </form>

        <div class="table-responsive bg-white p-3 shadow-sm rounded">
            <table class="table table-hover align-middle">
                <thead class="table-success">
                    <tr>
                        <th>ရက်စွဲ</th>
                        <th>တောင်သူ</th>
                        <th>အမျိုးအမည် (အမျိုးအစား)</th>
                        <th class="text-end">ရှင်းငွေ</th>
                        <th class="text-center">လုပ်ဆောင်ချက်</th> </tr>
                </thead>
                <tbody>
                    <% let monthlyTotal = 0; %>
                    <% if (records.length > 0) { %>
                        <% records.forEach(row => { %>
                            <% monthlyTotal += row.total_clearance; %>
                            <tr>
                                <td><%= row.date %></td>
                                <td><strong><%= row.farmer_name %></strong></td>
                                <td><%= row.item_name %> (<%= row.item_type %>)</td>
                                <td class="text-end text-dark font-weight-bold">
                                    <%= row.total_clearance.toLocaleString() %>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-2 justify-content-center">
                                        <a href="/edit-record/<%= row.id %>" class="btn btn-warning btn-sm">ပြင်မည်</a>
                                        
                                        <form action="/delete-record/<%= row.id %>" method="POST" onsubmit="return confirm('သေချာပါသလား?')">
                                            <button type="submit" class="btn btn-danger btn-sm">ဖျက်မည်</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <tr class="table-warning">
                            <td colspan="3" class="text-end"><strong>ဤလအတွက် စုစုပေါင်းရှင်းငွေ</strong></td>
                            <td class="text-end text-danger"><strong><%= monthlyTotal.toLocaleString() %> ကျပ်</strong></td>
                            <td></td>
                        </tr>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">ဤလအတွက် စာရင်းမရှိသေးပါ။</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>